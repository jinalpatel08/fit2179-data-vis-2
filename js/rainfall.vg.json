{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 350,
  "title": {
    "text": "Australia's Annual Rainfall, 1900–2025",
    "subtitle": "Total annual rainfall in millimetres. The dashed line shows the long-term average. Source: Bureau of Meteorology.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/rainfall.csv"
  },
  "transform": [
    {
      "calculate": "datum.rainfall < 400 ? 'Below 400mm' : 'Above 400mm'",
      "as": "RainfallCategory"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "#2166ac", "strokeDash": [6, 4], "strokeWidth": 1.5},
      "transform": [
        {"aggregate": [{"op": "mean", "field": "rainfall", "as": "mean_rainfall"}]}
      ],
      "encoding": {
        "y": {"field": "mean_rainfall", "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "area", "line": {"color": "#2166ac", "strokeWidth": 1.5}, "color": {"expr": "'url(#rainfall-gradient)'"}},
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {"title": null, "format": "d", "tickCount": 13}
        },
        "y": {
          "field": "rainfall",
          "type": "quantitative",
          "axis": {"title": "Annual rainfall (mm)", "grid": false},
          "scale": {"domain": [0, 800]}
        },
        "color": {"value": "#c6dbef"},
        "opacity": {"value": 0.7},
        "tooltip": [
          {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "rainfall", "type": "quantitative", "title": "Rainfall (mm)", "format": ".1f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.year == 2019"}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "dy": -10,
        "fontSize": 11,
        "color": "#d73027",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall", "type": "quantitative"},
        "text": {"value": "Driest year since 1900 (2019)"}
      }
    },
    {
      "transform": [{"filter": "datum.year == 2019"}],
      "mark": {"type": "point", "color": "#d73027", "size": 80, "filled": true},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall", "type": "quantitative"}
      }
    },
    {
      "transform": [{"filter": "datum.year == 1974"}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "dy": -10,
        "fontSize": 11,
        "color": "#2166ac",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall", "type": "quantitative"},
        "text": {"value": "Wettest year (1974)"}
      }
    },
    {
      "transform": [{"filter": "datum.year == 1974"}],
      "mark": {"type": "point", "color": "#2166ac", "size": 80, "filled": true},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall", "type": "quantitative"}
      }
    }
  ]
}