{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 450,

  "title": {
    "text": "Where is Australia warming fastest?",
    "subtitle": "Average temperature anomaly across Australian states and territories.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#777",
    "anchor": "start"
  },

  "projection": {
    "type": "mercator"
  },

  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/js/aus_states.json",
    "format": {
      "property": "features"
    }
  },

  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/state_temp_anomaly.csv"
        },
        "key": "state_name",
        "fields": ["anomaly"]
      }
    }
  ],

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1.2
  },

  "encoding": {
    "color": {
      "field": "anomaly",
      "type": "quantitative",
      "scale": {
        "scheme": "orangered",
        "domain": [0.9, 1.4]
      },
      "legend": {
        "title": "Temperature anomaly (°C)"
      }
    },

    "tooltip": [
      {
        "field": "properties.STATE_NAME",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "anomaly",
        "type": "quantitative",
        "title": "Anomaly (°C)",
        "format": ".2f"
      }
    ]
  }
}