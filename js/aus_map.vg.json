{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 450,
  "title": {
    "text": "Temperature Anomaly Across Australian States",
    "subtitle": "Average annual temperature anomaly (°C) above the 1961–1990 baseline, most recent decade. Source: Bureau of Meteorology.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "projection": {"type": "equirectangular"},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/js/aus_states.json",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape", "fill": "#ddd", "stroke": "white", "strokeWidth": 0.5}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/js/aus_states.json",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "transform": [
        {
          "lookup": "properties.NAME",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/state_temp_anomaly.csv"
            },
            "key": "state_name",
            "fields": ["anomaly"]
          }
        },
        {"filter": "datum.anomaly != null"}
      ],
      "mark": {"type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1.5},
      "encoding": {
        "color": {
          "field": "anomaly",
          "type": "quantitative",
          "scale": {
            "scheme": "orangered",
            "domain": [0.9, 1.4]
          },
          "legend": {
            "title": "Anomaly (°C)",
            "gradientLength": 200
          }
        },
        "tooltip": [
          {"field": "properties.NAME", "type": "nominal", "title": "State"},
          {"field": "anomaly", "type": "quantitative", "title": "Anomaly (°C)", "format": ".2f"}
        ]
      }
    }
  ]
}