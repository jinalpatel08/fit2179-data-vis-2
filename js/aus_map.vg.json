{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 450,
  "title": {
    "text": "Temperature Anomaly Across Australian States",
    "subtitle": "Average annual temperature anomaly (°C) above the 1961–1990 baseline, most recent decade. Source: Bureau of Meteorology.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "projection": {"type": "equirectangular"},
  "data": {
    "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.min.geojson",
    "format": {"type": "json", "property": "features"}
  },
  "transform": [
    {
      "calculate": "datum.properties.STATE_NAME",
      "as": "state_name"
    },
    {
      "lookup": "state_name",
      "from": {
        "data": {
          "values": [
            {"state_name": "New South Wales", "anomaly": 1.19},
            {"state_name": "Victoria", "anomaly": 1.21},
            {"state_name": "Queensland", "anomaly": 1.05},
            {"state_name": "South Australia", "anomaly": 1.32},
            {"state_name": "Western Australia", "anomaly": 1.13},
            {"state_name": "Tasmania", "anomaly": 0.95},
            {"state_name": "Northern Territory", "anomaly": 1.04},
            {"state_name": "Australian Capital Territory", "anomaly": 1.28}
          ]
        },
        "key": "state_name",
        "fields": ["anomaly"]
      }
    }
  ],
  "mark": {"type": "geoshape", "stroke": "#ffffff", "strokeWidth": 1.5},
  "encoding": {
    "color": {
      "field": "anomaly",
      "type": "quantitative",
      "scale": {
        "scheme": "orangered",
        "domain": [0.9, 1.4]
      },
      "legend": {
        "title": "Anomaly (°C)",
        "gradientLength": 200
      }
    },
    "tooltip": [
      {"field": "state_name", "type": "nominal", "title": "State"},
      {"field": "anomaly", "type": "quantitative", "title": "Anomaly (°C)", "format": ".2f"}
    ]
  }
}