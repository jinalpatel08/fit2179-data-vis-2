{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 620,
  "height": 360,
  "title": {
    "text": "Hotter Years Bring Less Rain",
    "subtitle": "Each dot is one year (1910–2020). As temperature anomaly rises, rainfall tends to fall. Hover to identify years.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/temp_rain_scatter.csv"
  },
  "layer": [
    {
      "mark": {"type": "rule", "color": "#dddddd", "strokeWidth": 1, "strokeDash": [4,3]},
      "transform": [
        {"aggregate": [{"op": "mean", "field": "rainfall", "as": "mean_rain"}]}
      ],
      "encoding": {"y": {"field": "mean_rain", "type": "quantitative"}}
    },
    {
      "mark": {"type": "rule", "color": "#dddddd", "strokeWidth": 1, "strokeDash": [4,3]},
      "encoding": {"x": {"datum": 0}}
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 70,
        "opacity": 0.75
      },
      "encoding": {
        "x": {
          "field": "Temperature",
          "type": "quantitative",
          "axis": {"title": "Temperature anomaly (°C)", "labelFontSize": 11, "grid": false},
          "scale": {"domain": [-1.3, 1.7]}
        },
        "y": {
          "field": "rainfall",
          "type": "quantitative",
          "axis": {"title": "Annual rainfall (mm)", "labelFontSize": 11, "grid": false},
          "scale": {"domain": [250, 780]}
        },
        "color": {
          "field": "decade",
          "type": "nominal",
          "scale": {
            "domain": ["1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s"],
            "scheme": "tableau10"
          },
          "legend": {"title": "Decade", "orient": "right", "labelFontSize": 11}
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Temp anomaly (°C)", "format": "+.2f"},
          {"field": "rainfall", "type": "quantitative", "title": "Rainfall (mm)", "format": ".0f"},
          {"field": "decade", "type": "nominal", "title": "Decade"}
        ]
      }
    },
    {
      "transform": [
        {
          "regression": "rainfall",
          "on": "Temperature"
        }
      ],
      "mark": {"type": "line", "color": "#c0392b", "strokeWidth": 2, "strokeDash": [6,3]},
      "encoding": {
        "x": {"field": "Temperature", "type": "quantitative"},
        "y": {"field": "rainfall", "type": "quantitative"}
      }
    }
  ]
}