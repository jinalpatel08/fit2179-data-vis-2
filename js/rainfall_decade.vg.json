{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 560,
  "height": 300,
  "title": {
    "text": "Drought Frequency by Decade, 1900–2020",
    "subtitle": "Number of years above and below the long-term average (461mm) per decade. Source: Bureau of Meteorology.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/rainfall_decade.csv"
  },
  "mark": {"type": "bar", "cornerRadiusTopLeft": 3, "cornerRadiusTopRight": 3},
  "encoding": {
    "x": {
      "field": "decade",
      "type": "ordinal",
      "sort": ["1900s","1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s","2020s"],
      "axis": {"title": null, "labelFontSize": 11, "labelAngle": -45}
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "stack": true,
      "axis": {"title": "Number of years", "grid": false, "labelFontSize": 11}
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "scale": {
        "domain": ["Above average", "Below average"],
        "range": ["#2471a3", "#c0392b"]
      },
      "legend": {"title": null, "orient": "top-right", "labelFontSize": 12}
    },
    "tooltip": [
      {"field": "decade", "type": "nominal", "title": "Decade"},
      {"field": "category", "type": "nominal", "title": "Category"},
      {"field": "count", "type": "quantitative", "title": "Years"}
    ]
  }
}