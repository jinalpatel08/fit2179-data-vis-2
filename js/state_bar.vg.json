{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 620,
  "height": 320,
  "title": {
    "text": "How Each State Compares to the National Average",
    "subtitle": "Deviation from the national average of 1.15°C. Red = above average, Blue = below average.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "values": [
      {"state": "South Australia", "anomaly": 1.32, "deviation": 0.17, "category": "Above national average"},
      {"state": "ACT", "anomaly": 1.28, "deviation": 0.13, "category": "Above national average"},
      {"state": "Victoria", "anomaly": 1.21, "deviation": 0.06, "category": "Above national average"},
      {"state": "New South Wales", "anomaly": 1.19, "deviation": 0.04, "category": "Above national average"},
      {"state": "Western Australia", "anomaly": 1.13, "deviation": -0.02, "category": "Below national average"},
      {"state": "Queensland", "anomaly": 1.05, "deviation": -0.10, "category": "Below national average"},
      {"state": "Northern Territory", "anomaly": 1.04, "deviation": -0.11, "category": "Below national average"},
      {"state": "Tasmania", "anomaly": 0.95, "deviation": -0.20, "category": "Below national average"}
    ]
  },
  "layer": [
    {
      "mark": {"type": "rule", "color": "#aaaaaa", "strokeDash": [5, 3], "strokeWidth": 1.5},
      "encoding": {"y": {"datum": 0}}
    },
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
