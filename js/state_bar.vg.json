{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 380,
  "title": {
    "text": "How Each State Compares to the National Average",
    "subtitle": "Temperature anomaly (°C) per state vs the national average of 1.15°C. Source: Bureau of Meteorology.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "data": {
    "values": [
      {"state": "New South Wales", "anomaly": 1.19, "national_avg": 1.15},
      {"state": "Victoria", "anomaly": 1.21, "national_avg": 1.15},
      {"state": "Queensland", "anomaly": 1.05, "national_avg": 1.15},
      {"state": "South Australia", "anomaly": 1.32, "national_avg": 1.15},
      {"state": "Western Australia", "anomaly": 1.13, "national_avg": 1.15},
      {"state": "Tasmania", "anomaly": 0.95, "national_avg": 1.15},
      {"state": "Northern Territory", "anomaly": 1.04, "national_avg": 1.15},
      {"state": "ACT", "anomaly": 1.28, "national_avg": 1.15}
    ]
  },
  "transform": [
    {
      "calculate": "datum.anomaly - datum.national_avg",
      "as": "deviation"
    },
    {
      "calculate": "datum.deviation > 0 ? 'Above national average' : 'Below national average'",
      "as": "category"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "#333333", "strokeDash": [4, 3], "strokeWidth": 1.5},
      "encoding": {
        "y": {"datum": 0}
      }
    },
    {
      "params": [
        {
          "name": "hover",
          "select": {"type": "point", "on": "mouseover", "clear": "mouseout"}
        }
      ],
      "mark": {"type": "bar", "cornerRadiusEnd": 3},
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "sort": "-y",
          "axis": {
            "title": null,
            "labelAngle": -30,
            "labelFontSize": 12
          }
        },
        "y": {
          "field": "deviation",
          "type": "quantitative",
          "axis": {
            "title": "Deviation from national average (°C)",
            "grid": false,
            "format": "+.2f"
          }
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Above national average", "Below national average"],
            "range": ["#d73027", "#4575b4"]
          },
          "legend": {"title": null}
        },
        "opacity": {
          "condition": {"param": "hover", "value": 1},
          "value": 0.75
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "anomaly", "type": "quantitative", "title": "Anomaly (°C)", "format": ".2f"},
          {"field": "deviation", "type": "quantitative", "title": "vs national avg (°C)", "format": "+.2f"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "dy": -8
      },
      "encoding": {
        "x": {
          "field": "state",
          "type": "nominal",
          "sort": "-y"
        },
        "y": {
          "field": "deviation",
          "type": "quantitative"
        },
        "text": {
          "field": "deviation",
          "type": "quantitative",
          "format": "+.2f"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Above national average", "Below national average"],
            "range": ["#d73027", "#4575b4"]
          }
        }
      }
    }
  ]
}