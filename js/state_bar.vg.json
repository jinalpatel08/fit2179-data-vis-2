        "x": {
          "field": "state",
          "type": "nominal",
          "sort": null,
          "axis": {"title": null, "labelAngle": -30, "labelFontSize": 11}
        },
        "y": {
          "field": "deviation",
          "type": "quantitative",
          "axis": {"title": "Deviation from national average (°C)", "grid": false, "format": "+.2f", "labelFontSize": 11}
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Above national average", "Below national average"],
            "range": ["#c0392b", "#2471a3"]
          },
          "legend": {"title": null, "orient": "top-right", "labelFontSize": 12}
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "anomaly", "type": "quantitative", "title": "Anomaly (°C)", "format": ".2f"},
          {"field": "deviation", "type": "quantitative", "title": "vs national avg", "format": "+.2f"}
        ]
      }
    }
  ]
