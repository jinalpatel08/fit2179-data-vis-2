{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 340,
  "title": {
    "text": "The Distribution of Annual Temperatures is Shifting Upward",
    "subtitle": "Each dot is one year. Decades are stacked vertically to show the rightward shift toward warmer temperatures over time.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/temp_strip.csv"
  },
  "layer": [
    {
      "mark": {"type": "rule", "color": "#dddddd", "strokeWidth": 1},
      "encoding": {"x": {"datum": 0}}
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "Temperature",
          "type": "quantitative",
          "axis": {"title": "Temperature anomaly (°C)", "labelFontSize": 11, "grid": false},
          "scale": {"domain": [-1.4, 1.7]}
        },
        "y": {
          "field": "decade",
          "type": "ordinal",
          "sort": ["1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s"],
          "axis": {"title": null, "labelFontSize": 12}
        },
        "color": {
          "field": "Temperature",
          "type": "quantitative",
          "scale": {"scheme": "redblue", "reverse": true, "domain": [-1.3, 1.6]},
          "legend": {"title": "Anomaly (°C)", "gradientLength": 150, "labelFontSize": 11}
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Anomaly (°C)", "format": "+.2f"},
          {"field": "decade", "type": "nominal", "title": "Decade"}
        ]
      }
    }
  ]
}