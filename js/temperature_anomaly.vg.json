{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 420,
  "title": {
    "text": "Australia's Warming Grid, 1910–2020",
    "subtitle": "Each cell is one year. Colour shows temperature anomaly from the 1961–1990 average. Click a decade to highlight it.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/temperature_anomaly.csv"
  },
  "transform": [
    {
      "calculate": "floor(datum.Year / 10) * 10",
      "as": "Decade"
    },
    {
      "calculate": "datum.Year % 10",
      "as": "YearWithinDecade"
    },
    {
      "calculate": "datum.Decade + 's'",
      "as": "DecadeLabel"
    }
  ],
  "params": [
    {
      "name": "selectedDecade",
      "select": {"type": "point", "fields": ["Decade"]},
      "bind": "legend"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rect", "stroke": "#ffffff", "strokeWidth": 2, "cornerRadius": 4},
      "encoding": {
        "x": {
          "field": "YearWithinDecade",
          "type": "ordinal",
          "axis": {
            "title": "Year within decade",
            "labelExpr": "datum.value == 0 ? '0' : datum.value == 9 ? '9' : datum.value",
            "labelFontSize": 11
          }
        },
        "y": {
          "field": "DecadeLabel",
          "type": "ordinal",
          "sort": ["1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s"],
          "axis": {"title": "Decade", "labelFontSize": 12}
        },
        "color": {
          "field": "Temperature",
          "type": "quantitative",
          "scale": {
            "scheme": "redblue",
            "reverse": true,
            "domain": [-1.5, 1.5]
          },
          "legend": {
            "title": "Anomaly (°C)",
            "gradientLength": 200
          }
        },
        "opacity": {
          "condition": {
            "param": "selectedDecade",
            "value": 1
          },
          "value": 0.2
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Anomaly (°C)", "format": "+.2f"},
          {"field": "DecadeLabel", "type": "nominal", "title": "Decade"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {
          "field": "YearWithinDecade",
          "type": "ordinal"
        },
        "y": {
          "field": "DecadeLabel",
          "type": "ordinal",
          "sort": ["1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s"]
        },
        "text": {
          "field": "Year",
          "type": "quantitative",
          "format": "d"
        },
        "color": {
          "condition": {"test": "abs(datum.Temperature) > 0.7", "value": "#ffffff"},
          "value": "#333333"
        },
        "opacity": {
          "condition": {
            "param": "selectedDecade",
            "value": 1
          },
          "value": 0.2
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Anomaly (°C)", "format": "+.2f"},
          {"field": "DecadeLabel", "type": "nominal", "title": "Decade"}
        ]
      }
    }
  ]
}