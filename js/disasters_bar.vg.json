{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 340,
  "title": {
    "text": "Australia's Extreme Weather Events, 2000–2025",
    "subtitle": "Number of recorded natural disasters per year by type. Click a type in the legend to isolate it. Source: EM-DAT.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/disasters.csv"
  },
  "params": [
    {
      "name": "disaster_select",
      "select": {"type": "point", "fields": ["disaster_type"]},
      "bind": "legend"
    }
  ],
  "mark": {"type": "bar", "cornerRadiusTopLeft": 2, "cornerRadiusTopRight": 2},
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "axis": {"title": null, "labelAngle": -45, "labelFontSize": 11}
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "aggregate": "sum",
      "axis": {"title": "Number of events", "grid": false, "labelFontSize": 11}
    },
    "color": {
      "field": "disaster_type",
      "type": "nominal",
      "scale": {
        "domain": ["Flood", "Storm", "Wildfire", "Drought", "Extreme temperature"],
        "range": ["#2471a3", "#74add1", "#c0392b", "#8c510a", "#e67e22"]
      },
      "legend": {"title": "Disaster type", "orient": "top-right", "labelFontSize": 12}
    },
    "opacity": {
      "condition": {"param": "disaster_select", "value": 1},
      "value": 0.2
    },
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "disaster_type", "type": "nominal", "title": "Type"},
      {"field": "count", "type": "quantitative", "title": "Events"}
    ]
  }
}