{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 580,
  "height": 420,
  "title": {
    "text": "Where Do Extreme Events Strike Most?",
    "subtitle": "Circle size shows total recorded extreme weather events per state, 2000–2025. Source: EM-DAT.",
    "fontSize": 15, "subtitleFontSize": 12, "subtitleColor": "#888", "anchor": "start"
  },
  "projection": {"type": "equirectangular", "center": [133, -28], "scale": 800, "translate": [290, 210]},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/js/aus_states.json",
        "format": {"property": "features"}
      },
      "mark": {"type": "geoshape", "fill": "#e8e4dc", "stroke": "#ffffff", "strokeWidth": 0.8}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/disaster_map.csv"
      },
      "mark": {"type": "circle", "opacity": 0.8, "stroke": "#c0392b", "strokeWidth": 1.5},
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "size": {
          "field": "total_events", "type": "quantitative",
          "scale": {"range": [200, 5000]},
          "legend": {"title": "Total events", "orient": "bottom-right"}
        },
        "color": {
          "field": "total_events", "type": "quantitative",
          "scale": {"scheme": "orangered", "domain": [0, 70]},
          "legend": null
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "total_events", "type": "quantitative", "title": "Total events"}
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/disaster_map.csv"
      },
      "mark": {"type": "text", "fontSize": 10, "fontWeight": "bold", "color": "#1a1a2e", "dy": -20},
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"}
      }
    }
  ]
}
