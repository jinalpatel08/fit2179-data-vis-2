{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 620,
  "height": 440,
  "title": {
    "text": "Where Do Extreme Events Strike Most?",
    "subtitle": "Circle size and colour show total recorded extreme weather events per state, 2000–2025. Source: EM-DAT.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "projection": {
    "type": "mercator",
    "center": [133, -27],
    "scale": 700,
    "translate": [310, 220]
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/js/aus_states.json",
        "format": {"property": "features"}
      },
      "mark": {"type": "geoshape", "fill": "#e8e4dc", "stroke": "#ffffff", "strokeWidth": 0.8}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/disaster_map.csv"
      },
      "mark": {"type": "circle", "opacity": 0.8, "stroke": "#ffffff", "strokeWidth": 1.5},
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "size": {
          "field": "total_events",
          "type": "quantitative",
          "scale": {"range": [300, 5000]},
          "legend": {"title": "Total events", "orient": "bottom-right", "labelFontSize": 11}
        },
        "color": {
          "field": "total_events",
          "type": "quantitative",
          "scale": {"scheme": "orangered", "domain": [0, 70]},
          "legend": null
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "total_events", "type": "quantitative", "title": "Total events"}
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/disaster_map.csv"
      },
      "mark": {"type": "text", "fontSize": 10, "fontWeight": "bold", "color": "#1a1a2e", "dy": -22},
      "encoding": {
        "longitude": {"field": "longitude", "type": "quantitative"},
        "latitude": {"field": "latitude", "type": "quantitative"},
        "text": {"field": "state", "type": "nominal"}
      }
    }
  ]
}