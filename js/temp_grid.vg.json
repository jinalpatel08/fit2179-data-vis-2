{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 400,
  "title": {
    "text": "Australia's Warming Grid — Every Year Since 1910",
    "subtitle": "Each cell is one year. Colour shows temperature anomaly (°C) from the 1961–1990 average. Click a decade row to highlight it.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/temperature_anomaly.csv"
  },
  "transform": [
    {"calculate": "floor(datum.Year / 10) * 10", "as": "Decade"},
    {"calculate": "datum.Year % 10", "as": "YearWithinDecade"},
    {"calculate": "datum.Decade + 's'", "as": "DecadeLabel"}
  ],
  "layer": [
    {
      "mark": {"type": "rect", "stroke": "#f5f4f0", "strokeWidth": 2, "cornerRadius": 3},
      "encoding": {
        "x": {
          "field": "YearWithinDecade",
          "type": "ordinal",
          "axis": {"title": "Year within decade", "labelFontSize": 11}
        },
        "y": {
          "field": "DecadeLabel",
          "type": "ordinal",
          "sort": ["1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s","2020s"],
          "axis": {"title": null, "labelFontSize": 12}
        },
        "color": {
          "field": "Temperature",
          "type": "quantitative",
          "scale": {"scheme": "redblue", "reverse": true, "domain": [-1.3, 1.6]},
          "legend": {"title": "Anomaly (°C)", "gradientLength": 180, "labelFontSize": 11}
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Anomaly (°C)", "format": "+.2f"},
          {"field": "DecadeLabel", "type": "nominal", "title": "Decade"}
        ]
      }
    },
    {
      "mark": {"type": "text", "fontSize": 10, "fontWeight": "600"},
      "encoding": {
        "x": {"field": "YearWithinDecade", "type": "ordinal"},
        "y": {
          "field": "DecadeLabel",
          "type": "ordinal",
          "sort": ["1910s","1920s","1930s","1940s","1950s","1960s","1970s","1980s","1990s","2000s","2010s","2020s"]
        },
        "text": {"field": "Year", "type": "quantitative", "format": "d"},
        "color": {
          "condition": {"test": "abs(datum.Temperature) > 0.65", "value": "#ffffff"},
          "value": "#444444"
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Anomaly (°C)", "format": "+.2f"}
        ]
      }
    }
  ]
}