{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 380,
  "title": {
    "text": "Australia's Annual Temperature Anomaly, 1910–2020",
    "subtitle": "Each dot shows how far that year's temperature was from the 1961–1990 average. Hover for details.",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/temperature_anomaly.csv"
  },
  "transform": [
    {
      "calculate": "datum.Temperature > 0 ? 'Warmer than average' : 'Cooler than average'",
      "as": "category"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "#cccccc", "strokeWidth": 1},
      "encoding": {
        "y": {"datum": 0}
      }
    },
    {
      "mark": {"type": "rule", "strokeWidth": 1},
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {"domain": [1910, 2020]},
          "axis": {"title": null, "format": "d", "tickCount": 12}
        },
        "y": {
          "field": "Temperature",
          "type": "quantitative",
          "axis": {"title": "Temperature anomaly (°C)", "grid": false}
        },
        "y2": {"datum": 0},
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Warmer than average", "Cooler than average"],
            "range": ["#d73027", "#4575b4"]
          },
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 50},
      "encoding": {
        "x": {
          "field": "Year",
          "type": "quantitative",
          "scale": {"domain": [1910, 2020]}
        },
        "y": {
          "field": "Temperature",
          "type": "quantitative"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Warmer than average", "Cooler than average"],
            "range": ["#d73027", "#4575b4"]
          },
          "legend": {
            "title": null,
            "orient": "top-left"
          }
        },
        "tooltip": [
          {"field": "Year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "Temperature", "type": "quantitative", "title": "Anomaly (°C)", "format": "+.2f"},
          {"field": "category", "type": "nominal", "title": "Category"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.Year == 2019"}],
      "mark": {
        "type": "text",
        "align": "right",
        "dx": -6,
        "dy": -10,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#d73027"
      },
      "encoding": {
        "x": {"field": "Year", "type": "quantitative", "scale": {"domain": [1910, 2020]}},
        "y": {"field": "Temperature", "type": "quantitative"},
        "text": {"value": "Hottest year (2019)"}
      }
    },
    {
      "transform": [{"filter": "datum.Year == 1917"}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": 10,
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#4575b4"
      },
      "encoding": {
        "x": {"field": "Year", "type": "quantitative", "scale": {"domain": [1910, 2020]}},
        "y": {"field": "Temperature", "type": "quantitative"},
        "text": {"value": "Coolest year (1917)"}
      }
    }
  ]
}