{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 620,
  "height": 300,
  "title": {
    "text": "The Long-Term Rainfall Trend is Declining",
    "subtitle": "10-year rolling average smooths year-to-year variability to reveal the underlying trend. Source: Bureau of Meteorology.",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "subtitleColor": "#888",
    "anchor": "start",
    "font": "Inter"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/jinalpatel08/fit2179-data-vis-2/main/data/rainfall_rolling.csv"
  },
  "layer": [
    {
      "transform": [{"filter": "datum.rainfall != null"}],
      "mark": {"type": "bar", "color": "#d6eaf8", "opacity": 0.5},
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {"title": null, "format": "d", "tickCount": 13, "labelFontSize": 11}
        },
        "y": {
          "field": "rainfall",
          "type": "quantitative",
          "axis": {"title": "Rainfall (mm)", "grid": false, "labelFontSize": 11},
          "scale": {"domain": [200, 800]}
        }
      }
    },
    {
      "transform": [{"filter": "datum.rolling_avg != null"}],
      "mark": {"type": "line", "color": "#2471a3", "strokeWidth": 3, "interpolate": "monotone"},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rolling_avg", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
          {"field": "rolling_avg", "type": "quantitative", "title": "10-yr avg (mm)", "format": ".0f"},
          {"field": "rainfall", "type": "quantitative", "title": "Annual (mm)", "format": ".0f"}
        ]
      }
    },
    {
      "transform": [
        {"filter": "datum.rolling_avg != null"},
        {"aggregate": [{"op": "mean", "field": "rolling_avg", "as": "grand_avg"}]}
      ],
      "mark": {"type": "rule", "color": "#c0392b", "strokeDash": [5,3], "strokeWidth": 1.5},
      "encoding": {"y": {"field": "grand_avg", "type": "quantitative"}}
    },
    {
      "transform": [{"filter": "datum.year == 1980 && datum.rolling_avg != null"}],
      "mark": {"type": "text", "align": "left", "dx": 6, "dy": -10, "fontSize": 11, "color": "#2471a3", "fontWeight": "bold"},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rolling_avg", "type": "quantitative"},
        "text": {"value": "10-year rolling average"}
      }
    }
  ]
}